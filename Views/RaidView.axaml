<UserControl
    x:Class="RAID_Util.Views.RaidView"
    x:Name="RaidViewControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel Spacing="10" Margin="10">

            <!-- Header bar for global array actions -->
            <Border Background="{DynamicResource BMWSurfaceElevatedBrush}"
                    Padding="12"
                    CornerRadius="4"
                    BorderBrush="{DynamicResource BMWBorderBrush}"
                    BorderThickness="1">

                <StackPanel Orientation="Horizontal" Spacing="10">

                    <Button Content="Create Array"
                            x:Name="BtnCreateArray"
                            Classes="HeaderButton"/>
                    <Button Content="Refresh"
                            x:Name="BtnRefreshArrays"
                            Classes="HeaderButton"/>

                    <Button Content="Config"
                            x:Name="BtnConfigArrays"
                            Classes="HeaderButton"/>

                    <Button Content="Delete Array"
                            x:Name="BtnDeleteArray"
                            Background="Red"
                            Foreground="WhiteSmoke"
                            Classes="HeaderButton"/>

                   

                </StackPanel>
            </Border>

            <!-- Array list container -->
            <StackPanel x:Name="ListArrays"
                        Spacing="8"/>
        </StackPanel>

    </ScrollViewer>

</UserControl>