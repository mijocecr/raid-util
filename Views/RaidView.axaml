<UserControl
    x:Class="RAID_Util.Views.RaidView"
    x:Name="RaidViewControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- ⭐ GRID PRINCIPAL -->
    <Grid RowDefinitions="Auto,*"
          Margin="10"
          RowSpacing="10">

        <!-- ⭐ HEADER FIJO (NO SCROLL) -->
        <Border Grid.Row="0"
                Background="{DynamicResource BMWSurfaceElevatedBrush}"
                Padding="12"
                CornerRadius="4"
                BorderBrush="{DynamicResource BMWBorderBrush}"
                BorderThickness="1">

            <Grid ColumnDefinitions="*,*,*"
                  RowDefinitions="Auto,Auto"
                  ColumnSpacing="10"
                  RowSpacing="10">

                <!-- FILA 1 -->
                <Button Grid.Row="0" Grid.Column="0"
                        Content="Create Array"
                        HorizontalAlignment="Stretch"
                        x:Name="BtnCreateArray"
                        Classes="HeaderButton"/>

                <Button Grid.Row="0" Grid.Column="1"
                        Content="Refresh"
                        HorizontalAlignment="Stretch"
                        x:Name="BtnRefreshArrays"
                        Classes="HeaderButton"/>

                <Button Grid.Row="0" Grid.Column="2"
                        Content="Config"
                        HorizontalAlignment="Stretch"
                        x:Name="BtnConfigArrays"
                        Classes="HeaderButton"/>

                <!-- FILA 2 -->
                <Button Grid.Row="1" Grid.Column="0"
                        Content="Assemble"
                        HorizontalAlignment="Stretch"
                        x:Name="BtnAssembleArrays"
                        Background="Green"
                        Foreground="WhiteSmoke"
                        Classes="HeaderButton"/>

                <Button Grid.Row="1" Grid.Column="1"
                        Content="Initialize"
                        HorizontalAlignment="Stretch"
                        x:Name="BtnInitialize"
                        Foreground="Black"
                        Background="Orange"
                        Classes="HeaderButton"/>

                <Button Grid.Row="1" Grid.Column="2"
                        Content="Delete Array"
                        HorizontalAlignment="Stretch"
                        x:Name="BtnDeleteArray"
                        Background="Red"
                        Foreground="WhiteSmoke"/>
            </Grid>
        </Border>

        <!-- ⭐ SOLO LA LISTA SCROLLEA -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ListArrays"
                        Spacing="8"/>
        </ScrollViewer>

    </Grid>

</UserControl>
