<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RAID_Util.Views.ArrayConfigWindow"
        Width="430" Height="560"
        Background="{DynamicResource BMWBackgroundBrush}"
        Foreground="{DynamicResource BMWTextBrush}"
        TransparencyLevelHint="AcrylicBlur"
        WindowStartupLocation="CenterOwner"
        Title="Array Configuration">

    <Grid RowDefinitions="Auto,*,Auto" Margin="16">

        <!-- TITLE -->
        <TextBlock Text="Array Configuration"
                   FontSize="20"
                   TextAlignment="Center"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource BMWTextBrush}"
                   Margin="0 0 0 12"/>

        <!-- MAIN SCROLL CONTENT -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="16">

                <!-- IDENTITY -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Identity"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BMWAccentBrush}"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowSpacing="6">

                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Array name"
                                       FontSize="12"
                                       Foreground="{DynamicResource BMWTextBrush}"/>
                            <TextBox x:Name="TxtName"
                                     Height="28"
                                     Width="180"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Volume label"
                                       FontSize="12"
                                       Foreground="{DynamicResource BMWTextBrush}"/>
                            <TextBox x:Name="TxtFsLabel"
                                     Height="28"
                                     Width="180"/>
                        </StackPanel>

                    </Grid>
                </StackPanel>

                <!-- MOUNT -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Mount"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BMWAccentBrush}"/>

                    <!-- ⭐ MOUNT POINT + BROWSE BUTTON -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Mount point"
                                   FontSize="12"
                                   Foreground="{DynamicResource BMWTextBrush}"/>

                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    HorizontalAlignment="Stretch">

                            <TextBox x:Name="TxtMountPoint"
                                     Height="28"
                                     Width="260"
                                     IsReadOnly="True"/>

                            <Button x:Name="BtnPickMountPoint"
                                    Content="Browse"
                                    Width="80"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="Mount options"
                               FontSize="12"
                               Margin="0 4 0 0"
                               Foreground="{DynamicResource BMWTextBrush}"/>

                    <!-- ⭐ 2 COLUMNAS -->
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="2">

                        <ToggleSwitch x:Name="TgNoAtime"
                                      Content="noatime"
                                      Grid.Row="0" Grid.Column="0"/>

                        <ToggleSwitch x:Name="TgNoDirAtime"
                                      Content="nodiratime"
                                      Grid.Row="0" Grid.Column="1"/>

                        <ToggleSwitch x:Name="TgDiscard"
                                      Content="discard (SSD)"
                                      Grid.Row="1" Grid.Column="0"/>

                        <ToggleSwitch x:Name="TgSync"
                                      Content="sync"
                                      Grid.Row="1" Grid.Column="1"/>

                        <ToggleSwitch x:Name="TgReadOnly"
                                      Content="Read-only (ro)"
                                      Grid.Row="2" Grid.Column="0"/>
                    </Grid>

                    <!-- ⭐ PERMISSIONS -->
                    <StackPanel Spacing="4" Margin="0 6 0 0">
                        <TextBlock Text="Permissions (chmod)"
                                   FontSize="12"
                                   Foreground="{DynamicResource BMWTextBrush}"/>

                        <TextBox x:Name="TxtMountPermissions"
                                 Height="28"
                                 Width="120"
                                 Watermark="777"
                                 Background="{DynamicResource BMWInputBrush}"
                                 Foreground="{DynamicResource BMWTextBrush}"
                                 BorderBrush="{DynamicResource BMWBorderBrush}"/>
                    </StackPanel>

                    <ToggleSwitch x:Name="TgAutoMount"
                                  Content="Auto-mount on startup"
                                  Margin="0 4 0 0"/>
                </StackPanel>

                <!-- PERFORMANCE -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Performance"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BMWAccentBrush}"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                        <StackPanel Spacing="2" Grid.Column="0">
                            <TextBlock Text="Resync priority"
                                       FontSize="12"
                                       Foreground="{DynamicResource BMWTextBrush}"/>
                            <NumericUpDown x:Name="NumResyncPriority"
                                           Minimum="1" Maximum="200000"
                                           Height="28"
                                           Width="180"/>
                        </StackPanel>

                        <StackPanel Spacing="2" Grid.Column="1">
                            <TextBlock Text="Speed limit"
                                       FontSize="12"
                                       Foreground="{DynamicResource BMWTextBrush}"/>
                            <NumericUpDown x:Name="NumResyncMaxSpeed"
                                           Minimum="100" Maximum="500000"
                                           Height="28"
                                           Width="180"/>
                        </StackPanel>

                    </Grid>
                </StackPanel>

                <!-- ALERTS -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Alerts"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BMWAccentBrush}"/>

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="2">

                        <ToggleSwitch x:Name="TgAlertDegraded"
                                      Content="Alert if degraded"
                                      Grid.Row="0" Grid.Column="0"/>

                        <ToggleSwitch x:Name="TgAlertDiskFail"
                                      Content="Alert on disk failure"
                                      Grid.Row="0" Grid.Column="1"/>

                        <ToggleSwitch x:Name="TgAlertSlowResync"
                                      Content="Alert on slow resync"
                                      Grid.Row="1" Grid.Column="0"/>
                    </Grid>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- ⭐ FIXED BUTTON BAR -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="8"
                    Margin="0 12 0 0">

            <Button x:Name="BtnCancel"
                    Content="Cancel"
                    HorizontalContentAlignment="Center"
                    Width="90" Height="30"/>

            <Button x:Name="BtnSave"
                    Content="Save"
                    HorizontalContentAlignment="Center"
                    Width="90" Height="30"/>
        </StackPanel>

    </Grid>
</Window>
