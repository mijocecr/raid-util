<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="clr-namespace:RAID_Util.Services"
    x:Class="RAID_Util.Views.Tabs.StatusView"
    Background="{DynamicResource BMWSurfaceBrush}"
    Foreground="{DynamicResource BMWTextBrush}">

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="18">

            <!-- ===================================================== -->
            <!-- 🟥 RAID HEALTH SUMMARY                                -->
            <!-- ===================================================== -->
            <Border Background="{DynamicResource BMWSurfaceElevatedBrush}"
                    BorderBrush="{DynamicResource BMWBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="18"
                    BoxShadow="0 2 6 0 #22000000">

                <StackPanel Spacing="12">

                    <TextBlock Text="RAID Health Summary"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource BMWTextBrush}"/>

                    <!-- Estado global -->
                    <Border Background="{DynamicResource BMWInputBrush}"
                            BorderBrush="{DynamicResource BMWBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12">

                        <TextBlock x:Name="TxtOverallRaidHealth"
                                   Text="Checking..."
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource BMWTextBrush}"/>
                    </Border>

                    <!-- Resumen numérico -->
                    <StackPanel Spacing="6">

                        <DockPanel LastChildFill="False">
                            <TextBlock Text="Arrays:"
                                       Width="150"
                                       Foreground="{DynamicResource BMWTextDimBrush}"/>
                            <TextBlock x:Name="TxtArraysSummary"
                                       Text="Loading..."
                                       FontWeight="SemiBold"/>
                        </DockPanel>

                        <DockPanel LastChildFill="False">
                            <TextBlock Text="Disks:"
                                       Width="150"
                                       Foreground="{DynamicResource BMWTextDimBrush}"/>
                            <TextBlock x:Name="TxtDisksSummary"
                                       Text="Loading..."
                                       FontWeight="SemiBold"/>
                        </DockPanel>

                        <DockPanel LastChildFill="False">
                            <TextBlock Text="Rebuilds:"
                                       Width="150"
                                       Foreground="{DynamicResource BMWTextDimBrush}"/>
                            <TextBlock x:Name="TxtRebuildSummary"
                                       Text="Loading..."
                                       FontWeight="SemiBold"/>
                        </DockPanel>

                    </StackPanel>

                </StackPanel>
            </Border>


            <!-- ===================================================== -->
            <!-- 🟧 ARRAYS AT RISK                                     -->
            <!-- ===================================================== -->
            <Border Background="{DynamicResource BMWSurfaceElevatedBrush}"
                    BorderBrush="{DynamicResource BMWBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="18"
                    BoxShadow="0 2 6 0 #22000000">

                <StackPanel Spacing="12">

                    <TextBlock Text="Arrays at Risk"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BMWTextBrush}"/>

                    <ItemsControl x:Name="ListArraysAtRisk">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:ArrayRiskInfo">

                                <Border Background="{DynamicResource BMWInputBrush}"
                                        BorderBrush="{DynamicResource BMWBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10"
                                        Margin="0 6">

                                    <StackPanel Spacing="4">

                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="16"
                                                   FontWeight="Bold"/>

                                        <TextBlock Text="{Binding Status}"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource BMWTextDimBrush}"/>

                                        <TextBlock Text="{Binding Details}"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource BMWTextBrush}"/>

                                    </StackPanel>

                                </Border>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </Border>


            <!-- ===================================================== -->
            <!-- 🟨 DISK ALERTS                                        -->
            <!-- ===================================================== -->
            <Border Background="{DynamicResource BMWSurfaceElevatedBrush}"
                    BorderBrush="{DynamicResource BMWBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="18"
                    BoxShadow="0 2 6 0 #22000000">

                <StackPanel Spacing="12">

                    <TextBlock Text="Disk Alerts"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BMWTextBrush}"/>

                    <ItemsControl x:Name="ListDiskAlerts">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:DiskAlertInfo">

                                <Border Background="{DynamicResource BMWInputBrush}"
                                        BorderBrush="{DynamicResource BMWBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10"
                                        Margin="0 6">

                                    <StackPanel Spacing="4">

                                        <TextBlock Text="{Binding Device}"
                                                   FontSize="15"
                                                   FontWeight="Bold"/>

                                        <TextBlock Text="{Binding Alert}"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource BMWTextDimBrush}"/>

                                    </StackPanel>

                                </Border>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </Border>


            <!-- ===================================================== -->
            <!-- 🟦 RECENT EVENTS                                      -->
            <!-- ===================================================== -->
            <Border Background="{DynamicResource BMWSurfaceElevatedBrush}"
                    BorderBrush="{DynamicResource BMWBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="18"
                    BoxShadow="0 2 6 0 #22000000">

                <StackPanel Spacing="12">

                    <TextBlock Text="Recent Events"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BMWTextBrush}"/>

                    <ItemsControl x:Name="ListRecentEvents">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">

                                <TextBlock Text="{Binding}"
                                           FontSize="13"
                                           Margin="0 4"
                                           Foreground="{DynamicResource BMWTextBrush}"/>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
