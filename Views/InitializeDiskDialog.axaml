<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RAID_Util.Views.InitializeDiskDialog"
        Width="360"
        Height="180"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="Initialize Disk"
        Background="{DynamicResource BMWSurfaceBrush}"
        BorderBrush="{DynamicResource BMWBorderBrush}"
        BorderThickness="1.4">

    <StackPanel Margin="10" Spacing="6">

        <TextBlock Text="Initialize Disk"
                   FontSize="15"
                   FontWeight="Bold"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center"
                   Foreground="{DynamicResource BMWTextBrush}" />

        <!-- GRID COMPACTO -->
        <Grid ColumnDefinitions="100, *"
              RowDefinitions="Auto,Auto"
              RowSpacing="6">

            <!-- Label -->
            <TextBlock Text="Label:"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource BMWAccentBrush}"
                       VerticalAlignment="Center"
                       Grid.Row="0" Grid.Column="0" />

            <TextBox x:Name="LabelBox"
                     Background="{DynamicResource BMWSurfaceElevatedBrush}"
                     Foreground="{DynamicResource BMWTextBrush}"
                     BorderBrush="{DynamicResource BMWBorderBrush}"
                     Height="24"
                     Watermark="Volume label"
                     Grid.Row="0" Grid.Column="1" />

            <!-- Filesystem -->
            <TextBlock Text="Filesystem:"
                       Foreground="{DynamicResource BMWAccentBrush}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Grid.Row="1" Grid.Column="0" />

            <ComboBox x:Name="FsCombo"
                      Background="{DynamicResource BMWSurfaceElevatedBrush}"
                      Foreground="{DynamicResource BMWTextBrush}"
                      BorderBrush="{DynamicResource BMWBorderBrush}"
                      Height="24"
                      HorizontalAlignment="Stretch"
                      Grid.Row="1" Grid.Column="1">

                <ComboBoxItem Content="ext4" />
                <ComboBoxItem Content="xfs" />
                <ComboBoxItem Content="btrfs" />
                <ComboBoxItem Content="f2fs" />
                <ComboBoxItem Content="ntfs" />
                <ComboBoxItem Content="exfat" />
                <ComboBoxItem Content="fat32" />

            </ComboBox>

        </Grid>

        <!-- BOTONES -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="6"
                    Margin="0,6,0,0">

            <Button x:Name="ApplyBtn"
                    Content="Initialize"
                    HorizontalContentAlignment="Center"
                    Height="30"
                    Classes="AccentButton" />

            <Button x:Name="CancelBtn"
                    Content="Cancel"
                    HorizontalContentAlignment="Center"
                    Height="30" />
        </StackPanel>

    </StackPanel>
</Window>