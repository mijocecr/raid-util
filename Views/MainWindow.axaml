<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:RAID_Util"
    xmlns:tabs="clr-namespace:RAID_Util.Views.Tabs"
    x:Class="RAID_Util.MainWindow"
    Width="500"
    Height="580"
    MinWidth="500"
    MinHeight="580"
    MaxWidth="500"
    MaxHeight="580"
    CanResize="False"
    Title="raid-util"
    Background="{DynamicResource BMWBackgroundBrush}"
    Foreground="{DynamicResource BMWTextBrush}">

    <!-- IMPORTA BMW -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://RAID-Util/Styles/BMWColors.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel>

        <!-- TOP BAR -->
        <Border Background="{DynamicResource BMWSurfaceElevatedBrush}" 
                BorderBrush="{DynamicResource BMWBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10"
                BoxShadow="0 2 6 0 #33000000"
                DockPanel.Dock="Top">

            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">

                <TextBlock 
                    Grid.Row="0" 
                    Grid.Column="0"
                    Text="RAID Management"
                    TextAlignment="Center"
                    FontSize="26"
                    FontWeight="Bold"
                    Foreground="{DynamicResource BMWTextBrush}"
                    VerticalAlignment="Center"/>

                <!-- BOTÓN CONFIGURACIÓN BMW -->
                <Button Content="⚙"
                        x:Name="SaveSettingButton"
                        Grid.Column="1"
                        Grid.Row="0"
                        Margin="10"
                        FontSize="18"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        Background="{DynamicResource BMWSurfaceBrush}"
                        Foreground="{DynamicResource BMWTextBrush}"
                        BorderBrush="{DynamicResource BMWAccentBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8">

                    <Button.Styles>
                        <Style Selector="Button:pointerover">
                            <Setter Property="Background" Value="{DynamicResource BMWHoverBrush}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource BMWAccentHoverBrush}"/>
                        </Style>
                        <Style Selector="Button:pressed">
                            <Setter Property="Background" Value="{DynamicResource BMWAccentBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </Button.Styles>

                </Button>
            </Grid>
        </Border>

        <!-- BOTTOM STATUS BAR -->
        <Border Background="{DynamicResource BMWSurfaceElevatedBrush}" 
                BorderBrush="{DynamicResource BMWBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="6"
                BoxShadow="0 -2 6 0 #22000000"
                DockPanel.Dock="Bottom">

            <TextBlock x:Name="StatusBarText"
                       Text="Ready."
                       TextAlignment="Center"
                       FontSize="14"
                       Foreground="{DynamicResource BMWTextDimBrush}"
                       Opacity="0.85"/>
        </Border>

        <!-- MAIN CONTENT -->
        <TabControl x:Name="MainTabs"
                    Background="{DynamicResource BMWSurfaceBrush}"
                    Foreground="{DynamicResource BMWTextBrush}"
                    BorderBrush="{DynamicResource BMWBorderBrush}"
                    BorderThickness="1"
                    Padding="6">

            <TabControl.Styles>

                <!-- TAB NORMAL -->
                <Style Selector="TabItem">
                    <Setter Property="Background" Value="{DynamicResource BMWSurfaceBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource BMWTextBrush}"/>
                    <Setter Property="Padding" Value="10,6"/>
                </Style>

                <!-- HOVER -->
                <Style Selector="TabItem:pointerover">
                    <Setter Property="Background" Value="{DynamicResource BMWHoverBrush}"/>
                </Style>

                <!-- SELECCIONADO -->
                <Style Selector="TabItem:selected">
                    <Setter Property="Background" Value="{DynamicResource BMWSurfaceElevatedBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource BMWAccentBrush}"/>
                    <Setter Property="BorderThickness" Value="0,0,0,3"/>
                </Style>

            </TabControl.Styles>

            <!-- STATUS TAB -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Status" Tag="0"
                               Foreground="{DynamicResource BMWTextBrush}"/>
                </TabItem.Header>

                <tabs:StatusView x:Name="StatusViewControl"/>
            </TabItem>

            <!-- RAID TAB -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="RAID" Tag="1"
                               Foreground="{DynamicResource BMWTextBrush}"/>
                </TabItem.Header>

                <!-- Se agregará más adelante -->
                <Grid/>
            </TabItem>

            <!-- JBOD TAB -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="JBOD" Tag="2"
                               Foreground="{DynamicResource BMWTextBrush}"/>
                </TabItem.Header>

                <!-- Se agregará más adelante -->
                <Grid/>
            </TabItem>

            <!-- DISKS TAB -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Disks" Tag="3"
                               Foreground="{DynamicResource BMWTextBrush}"/>
                </TabItem.Header>

                <!-- Se agregará más adelante -->
                <Grid/>
            </TabItem>

            <!-- LOGS TAB -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Logs" Tag="4"
                               Foreground="{DynamicResource BMWTextBrush}"/>
                </TabItem.Header>

                <tabs:LogsView x:Name="LogsViewControl"/>
            </TabItem>

        </TabControl>

    </DockPanel>
</Window>
