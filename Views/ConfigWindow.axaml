<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="RAID_Util.Views.ConfigWindow"
    Width="420"
    Height="360"
    CanResize="False"
    Title="Configuration"
    Background="{DynamicResource BMWBackgroundBrush}"
    Foreground="{DynamicResource BMWTextBrush}">

    <!-- BMW COLORS -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://RAID-Util/Styles/BMWColors.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Margin="18"
            Padding="18"
            Background="{DynamicResource BMWSurfaceElevatedBrush}"
            BorderBrush="{DynamicResource BMWBorderBrush}"
            BorderThickness="1"
            CornerRadius="10">

        <StackPanel Spacing="18">

            <!-- LOGS PANEL -->
            <StackPanel Spacing="10">

                <TextBlock Text="Global Logs"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource BMWTextBrush}" />

                <TextBlock Text="Logs folder"
                           Foreground="{DynamicResource BMWTextBrush}" />

                <DockPanel LastChildFill="False">
                    <TextBox x:Name="LogsPathBox"
                             Width="240"
                             IsReadOnly="True"
                             Background="{DynamicResource BMWInputBrush}"
                             Foreground="{DynamicResource BMWTextBrush}"
                             BorderBrush="{DynamicResource BMWBorderBrush}"
                             BorderThickness="1"
                             CornerRadius="6" />

                    <Button x:Name="BrowseLogsButton"
                            Content="Browse..."
                            Width="90"
                            Margin="10,0,0,0"
                            Background="{DynamicResource BMWSurfaceBrush}"
                            Foreground="{DynamicResource BMWTextBrush}"
                            BorderBrush="{DynamicResource BMWAccentBrush}"
                            BorderThickness="1"
                            CornerRadius="6" />
                </DockPanel>

                <TextBlock Text="Log level"
                           Foreground="{DynamicResource BMWTextBrush}" />

                <ComboBox x:Name="LogLevelCombo"
                          Width="150"
                          Background="{DynamicResource BMWSurfaceBrush}"
                          Foreground="{DynamicResource BMWTextBrush}"
                          BorderBrush="{DynamicResource BMWBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="6">
                    <ComboBoxItem Content="Basic" />
                    <ComboBoxItem Content="Normal" />
                    <ComboBoxItem Content="Detailed" />
                </ComboBox>

            </StackPanel>

            <!-- FINAL BUTTONS -->
            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button x:Name="SaveSettingsButton"
                        Content="Save Settings"
                        Width="130"
                        Height="34"
                        HorizontalAlignment="Left"
                        HorizontalContentAlignment="Center"
                        Grid.Column="0"
                        Background="{DynamicResource BMWSurfaceBrush}"
                        Foreground="{DynamicResource BMWTextBrush}"
                        BorderBrush="{DynamicResource BMWAccentBrush}"
                        BorderThickness="1"
                        CornerRadius="6" />

                <Button x:Name="CloseButton"
                        Content="Close"
                        Width="80"
                        Height="34"
                        HorizontalAlignment="Right"
                        HorizontalContentAlignment="Center"
                        Grid.Column="1"
                        Background="{DynamicResource BMWSurfaceBrush}"
                        Foreground="{DynamicResource BMWTextBrush}"
                        BorderBrush="{DynamicResource BMWAccentBrush}"
                        BorderThickness="1"
                        CornerRadius="6" />
            </Grid>

        </StackPanel>
    </Border>
</Window>
