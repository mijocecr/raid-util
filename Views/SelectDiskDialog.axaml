<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RAID_Util.Views.SelectDiskDialog"
        Width="350" Height="300"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Title="Select Disk">

    <StackPanel Margin="20">
        <TextBlock Text="Select a disk to add:" FontSize="16" Margin="0 0 0 10" />

        <ListBox x:Name="DiskList" Height="180" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 10 0 0">
            <Button x:Name="BtnCancel" Content="Cancel" Width="80" Margin="0 0 10 0" />
            <Button x:Name="BtnOK" Content="OK" Width="80" />
        </StackPanel>
    </StackPanel>
</Window>