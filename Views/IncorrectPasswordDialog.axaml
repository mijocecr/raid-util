<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RAID_Util.Views.IncorrectPasswordDialog"
        Width="380" Height="180"
        CanResize="False"
        Title="Authentication error">

    <Border Background="{DynamicResource BMWSurfaceBrush}"
            BorderBrush="{DynamicResource BMWBorderBrush}"
            BorderThickness="2"
            CornerRadius="10"
            Padding="18"
            Margin="6">

        <StackPanel Spacing="14">

            <TextBlock Text="The administrator password is incorrect."
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource BMWTextBrush}"
                       FontSize="14"/>

            <Button Content="OK"
                    Width="90"
                    Classes="BMWButton"
                    HorizontalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    Click="OnOk"/>

        </StackPanel>
    </Border>
</Window>