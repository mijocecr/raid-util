<UserControl
    x:Class="RAID_Util.Views.DisksView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,*"
          Margin="10"
          RowSpacing="10">

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="{DynamicResource BMWSurfaceElevatedBrush}"
                Padding="12"
                CornerRadius="4"
                BorderBrush="{DynamicResource BMWBorderBrush}"
                BorderThickness="1">

            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">

                <!-- TEXTOS -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Disk Workshop"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource BMWTextBrush}" />

                    <TextBlock Text="Inspect and prepare physical disks for RAID."
                               FontSize="14"
                               Foreground="{DynamicResource BMWTextDimBrush}" />
                </StackPanel>

                <!-- ⭐ BOTÓN REFRESH -->
                <Button Grid.Column="1"
                        x:Name="BtnRefresh"
                        Content="⟳ Refresh"
                        Margin="10 0 0 0"
                        Padding="12 6"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        />
            </Grid>
        </Border>

        <!-- LISTA SCROLLEABLE -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">

            <StackPanel x:Name="DiskList"
                        Spacing="10"
                        Margin="0 0 0 10"
                        HorizontalAlignment="Stretch" />
        </ScrollViewer>

    </Grid>

</UserControl>