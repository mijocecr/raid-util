<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================
         THEME DICTIONARIES (Light / Dark)
         ============================================ -->
    <ResourceDictionary.ThemeDictionaries>

        <!-- LIGHT (mejorado) -->
        <ResourceDictionary x:Key="Light">

            <!-- Background hierarchy -->
            <Color x:Key="BMWBackgroundColor">#EEF2F7</Color> <!-- gris-azulado suave -->
            <Color x:Key="BMWSurfaceColor">#FFFFFF</Color> <!-- blanco limpio -->
            <Color x:Key="BMWSurfaceElevatedColor">#F4F6FA</Color> <!-- panel elevado -->
            <Color x:Key="BMWInputColor">#E1E7EF</Color> <!-- input definido -->

            <!-- Text -->
            <Color x:Key="BMWTextColor">#0A0A0A</Color>
            <Color x:Key="BMWTextDimColor">#5A5A5A</Color>

            <!-- Accent -->
            <Color x:Key="BMWAccentColor">#1C69D4</Color>
            <Color x:Key="BMWAccentHoverColor">#2A7BFF</Color>

            <!-- Borders / Hover -->
            <Color x:Key="BMWBorderColor">#C4CCD6</Color> <!-- borde más visible -->
            <Color x:Key="BMWHoverColor">#E8EEF5</Color> <!-- hover suave -->
        </ResourceDictionary>

        <!-- DARK (sin cambios) -->
        <ResourceDictionary x:Key="Dark">

            <!-- Background hierarchy -->
            <Color x:Key="BMWBackgroundColor">#0D1117</Color>
            <Color x:Key="BMWSurfaceColor">#161B22</Color>
            <Color x:Key="BMWSurfaceElevatedColor">#1E242C</Color>
            <Color x:Key="BMWInputColor">#2A313A</Color>

            <!-- Text -->
            <Color x:Key="BMWTextColor">#E6E6E6</Color>
            <Color x:Key="BMWTextDimColor">#9AA0A6</Color>

            <!-- Accent -->
            <Color x:Key="BMWAccentColor">#1C69D4</Color>
            <Color x:Key="BMWAccentHoverColor">#2A7BFF</Color>

            <!-- Borders / Hover -->
            <Color x:Key="BMWBorderColor">#2D333B</Color>
            <Color x:Key="BMWHoverColor">#222830</Color>
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

    <!-- ============================================
         BRUSHES (estos sí van fuera)
         ============================================ -->
    <SolidColorBrush x:Key="BMWBackgroundBrush" Color="{DynamicResource BMWBackgroundColor}"/>
    <SolidColorBrush x:Key="BMWSurfaceBrush" Color="{DynamicResource BMWSurfaceColor}"/>
    <SolidColorBrush x:Key="BMWSurfaceElevatedBrush" Color="{DynamicResource BMWSurfaceElevatedColor}"/>
    <SolidColorBrush x:Key="BMWInputBrush" Color="{DynamicResource BMWInputColor}"/>

    <SolidColorBrush x:Key="BMWTextBrush" Color="{DynamicResource BMWTextColor}"/>
    <SolidColorBrush x:Key="BMWTextDimBrush" Color="{DynamicResource BMWTextDimColor}"/>

    <SolidColorBrush x:Key="BMWAccentBrush" Color="{DynamicResource BMWAccentColor}"/>
    <SolidColorBrush x:Key="BMWAccentHoverBrush" Color="{DynamicResource BMWAccentHoverColor}"/>

    <SolidColorBrush x:Key="BMWBorderBrush" Color="{DynamicResource BMWBorderColor}"/>
    <SolidColorBrush x:Key="BMWHoverBrush" Color="{DynamicResource BMWHoverColor}"/>

    <SolidColorBrush x:Key="BMWHealthHealthyBrush" Color="#4CAF50"/>
    <SolidColorBrush x:Key="BMWHealthWarningBrush" Color="#FFC107"/>
    <SolidColorBrush x:Key="BMWHealthCriticalBrush" Color="#F44336"/>
    <SolidColorBrush x:Key="BMWHealthNoneBrush" Color="#9E9E9E"/>

    
</ResourceDictionary>
