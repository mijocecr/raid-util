<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fluent="clr-namespace:Avalonia.Themes.Fluent;assembly=Avalonia.Themes.Fluent"
             x:Class="RAID_Util.App"
             RequestedThemeVariant="Default">

    <!-- ========================= -->
    <!--   RECURSOS (COLORES BMW)  -->
    <!-- ========================= -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <!-- ⭐ Tus colores BMW -->
                <ResourceInclude Source="avares://RAID-Util/Styles/BMWColors.axaml" />

            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <!-- ========================= -->
    <!--   ESTILOS (BMW + FLUENT)  -->
    <!-- ========================= -->
    <Application.Styles>

        <!-- Tema Fluent -->
        <fluent:FluentTheme />

        <!-- ⭐ Tus estilos BMW -->
        <StyleInclude Source="avares://RAID-Util/Styles/BMWStyles.axaml" />

        <!-- ========================= -->
        <!--   ICONO GLOBAL DE VENTANA -->
        <!-- ========================= -->
        <Style Selector="Window">
            <Setter Property="Icon"
                    Value="avares://RAID-Util/Assets/Icons/raid-util.png" />
        </Style>

    </Application.Styles>

</Application>