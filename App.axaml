<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fluent="clr-namespace:Avalonia.Themes.Fluent;assembly=Avalonia.Themes.Fluent"
             x:Class="RAID_Util.App"
             RequestedThemeVariant="Default">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <!-- COLORES BMW -->
                <ResourceInclude Source="avares://RAID-Util/Styles/BMWColors.axaml"/>

            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>

        <fluent:FluentTheme/>

        <!-- ESTILOS BMW -->
        <StyleInclude Source="avares://RAID-Util/Styles/BMWStyles.axaml"/>

    </Application.Styles>

</Application>