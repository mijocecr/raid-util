<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fluent="clr-namespace:Avalonia.Themes.Fluent;assembly=Avalonia.Themes.Fluent"
             x:Class="RAID_Util.App"
             RequestedThemeVariant="Default">

    <!-- ========================= -->
    <!--   RECURSOS (COLORES BMW)  -->
    <!-- ========================= -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <!-- PALETA BMW CON SOPORTE LIGHT/DARK -->
                <ResourceInclude Source="avares://RAID-Util/Styles/BMWColors.axaml"/>

            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <!-- ========================= -->
    <!--   ESTILOS (BMW + FLUENT)  -->
    <!-- ========================= -->
    <Application.Styles>

        <!-- Tema Fluent (obligatorio para ThemeVariant) -->
        <fluent:FluentTheme/>

        <!-- ESTILOS BMW (botones, bordes, textos, etc.) -->
        <StyleInclude Source="avares://RAID-Util/Styles/BMWStyles.axaml"/>

    </Application.Styles>

</Application>